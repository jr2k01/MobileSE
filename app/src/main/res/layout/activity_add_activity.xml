<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <TextView
        android:id="@+id/tvAddTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aktivität hinzufügen"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSelectSport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wähle eine Sportart:"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvAddTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <RadioGroup
        android:id="@+id/rgSports"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectSport"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/rbRunning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Laufen"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbCycling"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Radfahren"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbSwimming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schwimmen"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbStrength"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Krafttraining"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbOther"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sonstiges"
            android:textSize="16sp" />
    </RadioGroup>

    <Button
        android:id="@+id/btnSaveActivity"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="32dp"
        android:text="Hinzufügen"
        app:layout_constraintTop_toBottomOf="@id/rgSports"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnCancelAdd"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Abbrechen"
        app:layout_constraintTop_toBottomOf="@id/btnSaveActivity"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
