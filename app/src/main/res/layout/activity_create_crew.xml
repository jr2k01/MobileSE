<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Neue Crew erstellen"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <EditText
            android:id="@+id/etCrewName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name der Crew"
            android:inputType="text"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSaveCrew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crew speichern &amp; QR-Code generieren"/>

        <TextView
            android:id="@+id/tvQrInstruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dein Crew QR-Code:"
            android:textSize="18sp"
            android:layout_marginTop="32dp"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/ivCrewQrCode"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:contentDescription="Crew QR Code"/>

        <Button
            android:id="@+id/btnBackFromCrew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="Zurück"
            android:layout_marginTop="32dp"/>

    </LinearLayout>
</ScrollView>
