<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvCreateTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Neue Crew gründen"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:id="@+id/tilCrewName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Wie soll eure Crew heißen?"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvCreateTitle"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCrewName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSaveCrew"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Crew erstellen"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilCrewName" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvQrResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btnSaveCrew">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvQrInstruction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Euer Crew-QR-Code"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"/>

                <ImageView
                    android:id="@+id/ivCrewQrCode"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="24dp"
                    android:contentDescription="QR Code" />

                <TextView
                    android:id="@+id/tvCrewCodeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manueller Code:"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="24dp"/>

                <TextView
                    android:id="@+id/tvUniqueCrewCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CODE"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnBackFromCrew"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zurück"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cvQrResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
